# ─── Azure AD App Registration ───────────────────────────────
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_TENANT_ID=your-tenant-id-here

# Redirect URI - update to your server's URL for production
# Local:  http://localhost:5100/auth/callback
# Server: https://your-server-ip-or-domain:5100/auth/callback
REDIRECT_URI=http://localhost:5100/auth/callback

# ─── Flask ───────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=generate-a-random-secret-key-here

# Set to true if using HTTPS
SESSION_COOKIE_SECURE=false

# ─── Organization ───────────────────────────────────────────
ORG_DOMAIN=cloudfuze.com
MEETING_KEYWORDS=Customer Call,Migration Review,Client Meeting,Onboarding
ADMIN_EMAILS=bharath@cloudfuze.com

# Comma-separated migration manager emails (tracked separately on admin dashboard)
MANAGER_EMAILS=manager1@cloudfuze.com,manager2@cloudfuze.com

# ─── PostgreSQL ─────────────────────────────────────────────
# These are used by docker-compose to create the database container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=set-a-strong-password-here
POSTGRES_DB=meeting_moms

# Port for PostgreSQL on the host (default 5433 to avoid conflict with existing PostgreSQL)
DB_PORT=5433

# DATABASE_URL is auto-set by docker-compose; no need to change
# DATABASE_URL=postgresql://postgres:password@mom-db:5432/meeting_moms

# ─── Zoom (Server-to-Server OAuth) ──────────────────────────
# 1. Go to marketplace.zoom.us → Develop → Build App → Server-to-Server OAuth
# 2. Enable scopes: meeting:read:admin, recording:read:admin,
#                   user:read:admin, report:read:admin
# 3. Copy Account ID, Client ID, and Client Secret below.
ZOOM_ACCOUNT_ID=SVO7e1XbTH-kYNmUB3z9Mw
ZOOM_CLIENT_ID=HCBzIhkjTKWEEVuP0F9NZw
ZOOM_CLIENT_SECRET=BPtWJGPogI3in4hZm8StOZA5CjKbI5D1

# ─── OpenAI (for AI-powered MOM generation) ─────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ─── Daily audit email (optional; Graph application Mail.Send) ─
# Azure: grant Mail.Send (application permission) + admin consent.
# AUDIT_SENDER_MAILBOX must be a mailbox the app may send as (e.g. shared mailbox UPN).
# AUDIT_REPORT_RECIPIENTS = comma-separated To addresses.
# Run daily via cron: python scripts/send_audit_report.py
# AUDIT_REPORT_ENABLED=false skips cron only; Admin "Send audit report" still sends if mailbox/recipients are set.
AUDIT_REPORT_ENABLED=false
AUDIT_SENDER_MAILBOX=
AUDIT_REPORT_RECIPIENTS=
AUDIT_REPORT_DAYS=7
