# ─── Azure AD App Registration ───────────────────────────────
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_TENANT_ID=your-tenant-id-here

# Redirect URI (update to your server's public URL for production)
# For local:  http://localhost:5100/auth/callback
# For server: https://yourdomain.com/auth/callback
REDIRECT_URI=http://localhost:5100/auth/callback

# ─── Flask ───────────────────────────────────────────────────
FLASK_SECRET_KEY=generate-a-random-secret-key-here

# Set to true if using HTTPS in production
SESSION_COOKIE_SECURE=false

# ─── Organization ───────────────────────────────────────────
ORG_DOMAIN=cloudfuze.com

# Optional: comma-separated keywords to filter meeting subjects
MEETING_KEYWORDS=Customer Call,Migration Review,Client Meeting,Onboarding

# Comma-separated admin emails
ADMIN_EMAILS=bharath@cloudfuze.com

# ─── PostgreSQL (used by docker-compose) ────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password-here
POSTGRES_DB=meeting_moms

# DATABASE_URL is auto-set by docker-compose; override only for manual setup
# DATABASE_URL=postgresql://postgres:password@localhost:5432/meeting_moms

# ─── OpenAI (for AI-powered MOM generation) ─────────────────
OPENAI_API_KEY=your-openai-api-key-here
